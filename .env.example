# Engine TCP server port (C++ physics engine)
ENGINE_PORT=9001

# Engine hostname (use "engine" in Docker, "localhost" for local dev)
ENGINE_HOST=localhost

# Path to built frontend assets (set in Docker, leave unset for local dev)
# FRONTEND_DIR=/app/static

# Frontend env vars (used by Vite at build time)
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws/telemetry
